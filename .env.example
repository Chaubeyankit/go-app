APP_NAME=myapp
APP_ENV=development
APP_ADDR=:9090
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Main DB Connection
DATABASE_DSN=host=localhost user=postgres password=your_password dbname=myapp port=5432 sslmode=require

DATABASE_NAME=myapp
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
DATABASE_PORT=5432
DATABASE_SSLMODE=require
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_MAX_LIFETIME=5m

# REDIS CONNECTION
REDIS_HOST=localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Mail (SendGrid or SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your_sendgrid_api_key_here
SMTP_FROM=your-email@example.com

APP_URL=http://localhost:3000
LOCATION_API_KEY=your_location_api_key_here

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id_here
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth - GitHub
OAUTH_GITHUB_CLIENT_ID=your_github_client_id_here
OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret_here

APP_BASE_URL=http://localhost:9090

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your_jwt_access_secret_here_generate_with_openssl
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_generate_with_openssl

# Encryption Key for sensitive data (MFA secrets, OAuth tokens) - generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# Security Settings
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION=15m
MFA_RATE_LIMIT_ATTEMPTS=5
MFA_RATE_LIMIT_WINDOW=5m

# Rate Limiting for Auth Endpoints (login, signup, refresh)
# Increase these values during development to avoid delays


# For Development (no delays):

# Auth Endpoints (login, signup, refresh) - DEFAULT: 5 per 1 minute
AUTH_RATE_LIMIT_REQUESTS=10000
AUTH_RATE_LIMIT_WINDOW=1m

# MFA Challenge - DEFAULT: 5 per 5 minutes
MFA_RATE_LIMIT_ATTEMPTS=10000
MFA_RATE_LIMIT_WINDOW=5m

# Account Lockout - DEFAULT: 5 failed attempts, locked for 15 minutes
ACCOUNT_LOCKOUT_THRESHOLD=1000
ACCOUNT_LOCKOUT_DURATION=5m
